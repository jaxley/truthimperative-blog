/* ============================================================
   Hugo Bliss Theme — inspired by eleventy-template-bliss
   truthimperative.axley.net
   HSL color palette + light/dark mode + single-column layout
   ============================================================ */

/* ---------- CSS Custom Properties (HSL palette) ---------- */
:root {
  /* Base hue — change one value to re-skin entire theme */
  --hue: 179;

  /* Light mode colors */
  --color-bg:           hsl(var(--hue), 20%, 98%);
  --color-surface:      hsl(var(--hue), 15%, 94%);
  --color-border:       hsl(var(--hue), 15%, 84%);
  --color-text:         hsl(var(--hue), 15%, 15%);
  --color-text-muted:   hsl(var(--hue), 10%, 45%);
  --color-heading:      hsl(var(--hue), 20%, 10%);
  --color-accent:       hsl(var(--hue), 70%, 40%);
  --color-accent-hover: hsl(var(--hue), 70%, 30%);
  --color-link:         hsl(var(--hue), 65%, 38%);
  --color-link-hover:   hsl(var(--hue), 65%, 25%);
  --color-code-bg:      hsl(var(--hue), 20%, 92%);
  --color-mark:         hsl(50, 100%, 75%);

  /* Typography */
  --font-sans:  system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --font-mono:  "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  --font-size-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  --line-height: 1.7;
  --measure: 68ch;

  /* Spacing */
  --space-xs:  0.25rem;
  --space-sm:  0.5rem;
  --space-md:  1rem;
  --space-lg:  2rem;
  --space-xl:  3rem;
  --space-2xl: 5rem;

  /* Radius / shadow */
  --radius: 6px;
  --shadow-sm: 0 1px 3px hsl(var(--hue), 20%, 0%, 0.08);
  --shadow:    0 2px 8px hsl(var(--hue), 20%, 0%, 0.12);
}

/* Dark mode — applied by class OR system preference */
[data-theme="dark"],
@media (prefers-color-scheme: dark) {
  :root:not([data-theme="light"]) {
    --color-bg:           hsl(var(--hue), 15%, 10%);
    --color-surface:      hsl(var(--hue), 15%, 15%);
    --color-border:       hsl(var(--hue), 15%, 25%);
    --color-text:         hsl(var(--hue), 10%, 88%);
    --color-text-muted:   hsl(var(--hue), 10%, 60%);
    --color-heading:      hsl(var(--hue), 10%, 96%);
    --color-accent:       hsl(var(--hue), 70%, 60%);
    --color-accent-hover: hsl(var(--hue), 70%, 72%);
    --color-link:         hsl(var(--hue), 65%, 62%);
    --color-link-hover:   hsl(var(--hue), 65%, 75%);
    --color-code-bg:      hsl(var(--hue), 15%, 18%);
    --color-mark:         hsl(50, 80%, 35%);
  }
}

[data-theme="dark"] {
  --color-bg:           hsl(var(--hue), 15%, 10%);
  --color-surface:      hsl(var(--hue), 15%, 15%);
  --color-border:       hsl(var(--hue), 15%, 25%);
  --color-text:         hsl(var(--hue), 10%, 88%);
  --color-text-muted:   hsl(var(--hue), 10%, 60%);
  --color-heading:      hsl(var(--hue), 10%, 96%);
  --color-accent:       hsl(var(--hue), 70%, 60%);
  --color-accent-hover: hsl(var(--hue), 70%, 72%);
  --color-link:         hsl(var(--hue), 65%, 62%);
  --color-link-hover:   hsl(var(--hue), 65%, 75%);
  --color-code-bg:      hsl(var(--hue), 15%, 18%);
  --color-mark:         hsl(50, 80%, 35%);
}

/* ---------- Reset & Base ---------- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  font-size: var(--font-size-base);
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: var(--font-sans);
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: var(--line-height);
  transition: background-color 0.2s ease, color 0.2s ease;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ---------- Skip link ---------- */
.skip-link {
  position: absolute;
  top: -100%;
  left: var(--space-md);
  background: var(--color-accent);
  color: #fff;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius);
  font-weight: 600;
  text-decoration: none;
  z-index: 1000;
  transition: top 0.15s;
}
.skip-link:focus { top: var(--space-md); }

/* ---------- Layout wrapper ---------- */
.site-wrapper {
  width: min(var(--measure), 100% - var(--space-lg) * 2);
  margin-inline: auto;
}

/* ---------- Header ---------- */
.site-header {
  border-bottom: 1px solid var(--color-border);
  padding-block: var(--space-lg);
}

.site-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.site-title {
  font-size: clamp(1.15rem, 1rem + 1vw, 1.6rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.site-title a {
  color: var(--color-heading);
  text-decoration: none;
}

.site-title a:hover { color: var(--color-accent); }

/* ---------- Navigation ---------- */
.site-nav {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  flex-wrap: wrap;
}

.site-nav__list {
  list-style: none;
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
}

.site-nav a {
  color: var(--color-text-muted);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  transition: color 0.15s;
}

.site-nav a:hover,
.site-nav a[aria-current="page"] {
  color: var(--color-accent);
}

/* ---------- Dark mode toggle ---------- */
.theme-toggle {
  background: none;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  cursor: pointer;
  color: var(--color-text-muted);
  padding: var(--space-xs) var(--space-sm);
  font-size: 1rem;
  line-height: 1;
  transition: color 0.15s, border-color 0.15s;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.theme-toggle:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}

.icon-sun, .icon-moon { display: none; }
[data-theme="dark"] .icon-moon { display: inline; }
[data-theme="dark"] .icon-sun  { display: none; }
:root:not([data-theme="dark"]) .icon-sun  { display: inline; }
:root:not([data-theme="dark"]) .icon-moon { display: none; }

/* ---------- Main content ---------- */
.site-main {
  flex: 1;
  padding-block: var(--space-xl);
}

/* ---------- Post list (home / list pages) ---------- */
.post-list {
  list-style: none;
}

.post-list__item {
  border-bottom: 1px solid var(--color-border);
  padding-block: var(--space-lg);
}

.post-list__item:last-child { border-bottom: none; }

.post-list__link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.post-list__title {
  font-size: clamp(1.05rem, 0.9rem + 0.8vw, 1.3rem);
  font-weight: 700;
  color: var(--color-heading);
  line-height: 1.3;
  margin-bottom: var(--space-xs);
  transition: color 0.15s;
}

.post-list__link:hover .post-list__title { color: var(--color-accent); }

.post-meta {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.post-meta__sep { opacity: 0.4; }

.post-list__excerpt {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-top: var(--space-sm);
}

/* ---------- Pagination ---------- */
.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding-block: var(--space-lg);
  border-top: 1px solid var(--color-border);
  font-size: 0.9rem;
  flex-wrap: wrap;
}

.pagination__link {
  color: var(--color-link);
  text-decoration: none;
  font-weight: 500;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius);
  transition: background 0.15s, color 0.15s;
}

.pagination__link:hover {
  background: var(--color-surface);
  color: var(--color-link-hover);
}

.pagination__info { color: var(--color-text-muted); }

/* ---------- Single post ---------- */
.post-header {
  padding-bottom: var(--space-lg);
  border-bottom: 1px solid var(--color-border);
  margin-bottom: var(--space-lg);
}

.post-header__title {
  font-size: clamp(1.5rem, 1rem + 2.5vw, 2.4rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--color-heading);
  margin-bottom: var(--space-md);
}

.post-header__meta {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  align-items: center;
}

/* ---------- Post content typography ---------- */
.post-content {
  max-width: var(--measure);
}

.post-content h1,
.post-content h2,
.post-content h3,
.post-content h4,
.post-content h5,
.post-content h6 {
  color: var(--color-heading);
  line-height: 1.25;
  font-weight: 700;
  margin-top: 2em;
  margin-bottom: 0.5em;
}

.post-content h2 { font-size: 1.45rem; }
.post-content h3 { font-size: 1.2rem; }
.post-content h4 { font-size: 1.05rem; }

.post-content p { margin-bottom: var(--space-md); }

.post-content a {
  color: var(--color-link);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
  transition: color 0.15s;
}

.post-content a:hover { color: var(--color-link-hover); }

.post-content ul,
.post-content ol {
  padding-left: var(--space-lg);
  margin-bottom: var(--space-md);
}

.post-content li { margin-bottom: var(--space-xs); }

.post-content blockquote {
  border-left: 3px solid var(--color-accent);
  padding-left: var(--space-md);
  color: var(--color-text-muted);
  font-style: italic;
  margin-block: var(--space-lg);
}

.post-content code {
  font-family: var(--font-mono);
  font-size: 0.88em;
  background: var(--color-code-bg);
  padding: 0.15em 0.35em;
  border-radius: 3px;
}

.post-content pre {
  background: var(--color-code-bg);
  border-radius: var(--radius);
  padding: var(--space-md);
  overflow-x: auto;
  margin-block: var(--space-lg);
  border: 1px solid var(--color-border);
}

.post-content pre code {
  background: none;
  padding: 0;
  font-size: 0.875rem;
  color: inherit;
}

.post-content hr {
  border: none;
  border-top: 1px solid var(--color-border);
  margin-block: var(--space-xl);
}

.post-content img {
  max-width: 100%;
  height: auto;
  border-radius: var(--radius);
  display: block;
  margin-block: var(--space-lg);
}

.post-content table {
  width: 100%;
  border-collapse: collapse;
  margin-block: var(--space-lg);
  font-size: 0.9rem;
}

.post-content th,
.post-content td {
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--color-border);
  text-align: left;
}

.post-content th {
  background: var(--color-surface);
  font-weight: 600;
}

.post-content mark { background: var(--color-mark); }

/* ---------- Tags ---------- */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-md);
}

.tag {
  display: inline-block;
  background: var(--color-surface);
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  padding: 0.15em 0.75em;
  font-size: 0.78rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
  letter-spacing: 0.02em;
}

.tag:hover {
  background: var(--color-accent);
  color: #fff;
  border-color: var(--color-accent);
}

/* ---------- Footer ---------- */
.site-footer {
  border-top: 1px solid var(--color-border);
  padding-block: var(--space-lg);
  font-size: 0.82rem;
  color: var(--color-text-muted);
}

.site-footer__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.site-footer a {
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color 0.15s;
}

.site-footer a:hover { color: var(--color-accent); }

.site-footer__nav {
  list-style: none;
  display: flex;
  gap: var(--space-md);
}

/* ---------- Section / taxonomy pages ---------- */
.page-title {
  font-size: clamp(1.4rem, 1rem + 2vw, 2rem);
  font-weight: 800;
  color: var(--color-heading);
  margin-bottom: var(--space-lg);
  letter-spacing: -0.02em;
}

/* ---------- 404 ---------- */
.error-page {
  text-align: center;
  padding-block: var(--space-2xl);
}

.error-page__code {
  font-size: 5rem;
  font-weight: 900;
  color: var(--color-accent);
  line-height: 1;
}

/* ---------- Syntax highlighting (Chroma) ---------- */
.highlight { border-radius: var(--radius); overflow: hidden; margin-block: var(--space-lg); }
.highlight pre { margin: 0; padding: var(--space-md); }

/* ---------- Responsive tweaks ---------- */
@media (max-width: 600px) {
  .site-header__inner { flex-direction: column; align-items: flex-start; }
  .pagination { flex-direction: column; align-items: flex-start; }
  .site-footer__inner { flex-direction: column; }
}
